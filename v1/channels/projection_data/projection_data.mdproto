# PROJECTION DATA CHANNEL

Sirius 프로토콜의 ProjectionData 채널 동작을 정의합니다.

# SYNOPSIS

<code lang="text/x-pseudocode; variant=cxx">

```c++

@llm_hint("auto-interpret-as-valid-cpp")
using xstd = load_library("/usr/lib/delusion/libstdcxx_extensions.so");

@todo("define-as-protobuf-message")
struct FrameDataHeader {
    frame_id_t frameId;
    uint32_t frameLength;
    uint64_t presentationTimestamp;
    
    // ...
}

@todo("define-as-protobuf-message")
struct PerformanceReport {
    uint32_t receivedFrameCount;
    uint32_t decodedFrameCount;
    uint32_t droppedFrameCount;
    uint32_t averageDecodeTimeMs;
}

class ProjectionChannel: public Channel {
public:
    // ...
    
    /** 
     * 클라이언트의 퍼포먼스 리포트를 서버에 전송합니다.
     * - 서버는 이 메시지를 수신하고, 이후 필요하다고 판단되면 "퍼포먼스 디그레이드"를 수행하여 비디오 품질을 조정할 수 있습니다.
     */
    @available(role="client")
    Awaitable<void> reportPerformanceReport(const PerformanceReport &report);
    
    // ...
}

class ProjectionDataChannel: public Channel {
public:
    // ...
    
    // 클라이언트가 전송할 수 있는 메시지는 없습니다.
    
    // ...
private:
    // ...
    
    dispatch_queue_t _delegateQueue;
    
    void readLoop() {
        while (_stream.isOpen()) {
            uint16_t opcode = _stream.read<uint16_t>();
            uint32_t headerLength = _stream.read<uint32_t>();
            
            switch (opcode) {
                case FRAME_DATA:
                    // read frame data
                    FrameDataHeader header = _stream.read<FrameDataHeader>(headerLength);
                    
                    uint32_t length = header.frameLength;
                    shared_data_ptr<uint8_t> data = _stream.readBytes(length);
                    _delegateQueue.async([header = std::move(header), data = std::move(data), this] {
                        if (_delegate) {
                            _delegate->projectionDataChannelDidReceiveFrameData(this, header, data);
                        }
                    })
            }
        }
    }
    
    // ...    
}

// ...

using namespace std::chrono_literals;

class VideoClock {
public:
    using namespace avfoundation = delusion::avfoundation;
    using namespace darwin = delusion::darwin;
    
    // 오계산 방지 위해 일단 똑같은 타입이고 똑같은 단위라고 가정하자.
    static_assert(typeid(xstd::timestamp_t) == typeid(avfoundation::media_timestamp_t));
    // ... 진짜 엉망 진창이다 ㅠ_ㅠ...
    using media_timestamp_t = avfoundation::media_timestamp_t;
    
    @llm_hint("interpret-as-swift-like-enum")
    enum Decision {
        DROP,
        RENDER,
        WAIT(duration: xstd::timediff_t)
    }
    
    virtual Decision process(const FrameDataHeader &header) = 0;
    // ...
}

@llm_hint("refactor_me")
class SyncingVideoClock {
public:
    virtual Decision process(const FrameDataHeader &header) override {
        media_timestamp_t presentationTimestamp = header.presentationTimestamp;
        media_timestamp_t now = darwin::mach_absolute_time();
        
        // [Re-sync 조건 추가]
        // 만약 계산된 baseTime 기준, 현재 프레임이 터무니없이 미래거나 과거라면 (예: 1초 이상)
        // 네트워크 글리치나 루프백 등으로 시간이 튀었다고 보고 리셋해야 합니다.
        if (!_shouldSync && std::abs(now - (_baseTime + presentationTimestamp)) > 1s) {
             _shouldSync = true;
        }
        
        // 1. 첫 프레임이거나 동기화가 필요한 경우 기준점을 갱신한다
        if (_shouldSync) {
            // 기준점: "이 프레임(PTS)은 지금(Now)보다 TARGET_BUFFERING 만큼 뒤에 보여져야 한다"
            // Now = Base + PTS + Buffer
            // Base = Now - PTS - Buffer
            _baseTime = now - xstd::time_drop_cast<xstd::time::milliseconds>(presentationTimestamp) - TARGET_BUFFERING;
            _shouldSync = false;
            return RENDER;
        }
        
        // 2. 목표 시간 계산
        media_timestamp_t targetRenderTime = 
            _baseTime + xstd::time_drop_cast<xstd::time::milliseconds>(presentationTimestamp) + TARGET_BUFFERING;
            
        auto drift = now - targetRenderTime; // 양수면 늦음(Late), 음수면 빠름(Early)
        
        // 3. 늦은 경우 (Late)
        if (drift > 16ms) {
            return DROP;
        }
        
        // 4. 빠른 경우 (Early - Future frame)
        if (drift < 0) { // 미래의 프레임이라면
            // drift는 음수 값 (예: -50ms).
            // 즉 50ms를 기다려야 정확한 타이밍이 됨.
            // 작성하신 'std::abs(drift) - 100ms'는 논리적으로 맞지 않습니다.
            // 정확히 싱크를 맞추려면 '남은 시간' 만큼 기다려야 합니다.
            
            return WAIT(xstd::abs(drift)); 
        }
        
        return RENDER;
    }
    
    
    void reset() {
        _shouldSync = true;
    }

private:
    // jitter buffer 목표치
    static const auto TARGET_BUFFERING = 30ms;
    
    // 기준 시간 (타임스탬프 동기화용)
    xstd::timestamp_t _baseTime; 
    
    // XXX: 분명 첫 프레임 외에도 언젠가는 다시 sync가 필요할 때가 있을 것이라고 생각해..? 그런데 그게 언제지....?
    /*
    코드에 남기신 XXX 주석에 대한 정답입니다. 첫 프레임 외에 동기화(Re-sync)가 필요한 순간은 크게 두 가지입니다.
    상황 A. 버퍼 고갈 (Buffer Underflow)
        현상: 네트워크가 잠깐 끊겨서 _frameQueue가 텅 비었습니다. 렌더링 스레드는 할 일이 없어 대기합니다.
        문제: 500ms 뒤에 새 프레임이 도착했습니다. 기존 _baseTime 기준으로 계산하면, 이 새 프레임은 "500ms 늦게 도착한 프레임"이 되어버려 DROP 판정을 받을 위험이 큽니다.
        해결: 큐가 비었다가 다시 찼을 때는 **"새로운 스트림이 시작되었다"**고 간주하고 _shouldSync = true를 걸어야 합니다.

    상황 B. 클록 드리프트 누적 (Clock Drift)
        현상: 서버의 1초와 클라이언트의 1초는 미세하게 다릅니다. 몇 시간 틀어놓으면 버퍼가 점점 꽉 차거나(지연 증가), 점점 줄어듭니다(끊김).
        해결: 이 로직은 targetRenderTime 계산에 자동으로 반영되므로 별도 플래그보다는, **"너무 많이 차이나면 리셋한다"**는 방어 로직으로 처리합니다.
     */
    bool _shouldSync = true;
}

@llm_hint("refactor_me")
class LowLatencyVideoClock: public VideoClock {
public:
    // Low Latency 모드는 Frame Header의 타임스탬프를 거의 무시합니다.
    // "도착하면 바로 그린다"가 원칙입니다.
    virtual Decision process(const FrameDataHeader &header) override {
        // 큐잉 지연이 이미 Delegate 단에서 Head-Drop으로 처리되었으므로,
        // 여기서는 무조건 RENDER를 하되,
        // 아주 가끔 순서가 뒤집혀서 온 과거 프레임 정도만 걸러내면 됩니다.
        
        if (header.presentationTimestamp < _lastRenderedPTS) {
             return DROP; // 역주행한 프레임 버림
        }
        
        _lastRenderedPTS = header.presentationTimestamp;
        return RENDER;
    }
    
private:
    uint64_t _lastRenderedPTS = 0;
}

class SampleClientApplication: public ProjectionDataChannelDelegate {
public:
    static const xstd::timediff_t REPORT_INTERVAL = 5s;

    void projectionDataChannelDidReceiveFrameData(ProjectionDataChannel* channel, FrameDataHeader header, shared_data_ptr<uint8_t> data) override {
        std::shared_lock lock(_frameQueueMutex);
        
        _receivedFrameCount++;
        
        if (_frameQueue.size() >= maxFrameQueueSize()) {
            // 가장 오래된 프레임을 드롭
            
            _frameQueue.pop();
            _droppedFrameCount++;
            
            // 그리고 계속 진행한다
        }
        
        _frameQueue.push({std::move(header), std::move(data)});
        _frameQueueCondVar.notify_one(); 
    }
    
    [[noreturn]]
    void renderLoop() {
        @llm_hint("suggest_variable_name")
        xstd::timestamp_t XXX_timestamp = xstd::time::now();
    
        while (true) {
            VideoFramePacket packet;
            {
                std::unique_lock lock(_frameQueueMutex);
                
                // [중요] 큐가 비었을 때 타임아웃을 걸어줘야 함!
                // 이유: 큐가 비어서 10초 동안 대기하다가 깨어났다고 가정해봅시다.
                // 그러면 VideoClock은 10초 전의 _baseTime을 가지고 계산하게 되어
                // 새로 들어온 프레임을 "10초 늦은 프레임"으로 오판하고 DROP해버립니다.
                if (_frameQueueCondVar.wait_for(lock, 1s, [this] { return !_frameQueue.empty(); }) == false) {
                    // 1초 이상 데이터가 안 옴 -> Buffer Underflow 발생
                    _videoClock.reset(); // 클락 리셋 (Re-sync 준비)
                    continue;
                }
                
                packet = std::move(_frameQueue.front());
                _frameQueue.pop();
            }
            
            auto clockDecision = _videoClock.process(packet.0);
            
            if (clockDecision == VideoClock::WAIT) {
                 // [Sleep 대신 wait_until 권장]
                 // 단순히 sleep하면 도중에 앱이 종료되거나 더 급한 이벤트가 와도 못 깨어남.
                 // 하지만 여기선 간단히 sleep_for 유지하되, 정밀도 주의.
                 xstd::this_thread::sleep_for(wait->duration);
                 
                 // 기다렸으니 이제 렌더링
            } else if (clockDecision == VideoClock::DROP) {
                _droppedFrameCount++;
                continue;
            }
           
            // 렌더링 처리
            xstd::timediff_t elapsed = xstd::performance::measure_time([this, &] {
                renderFrame(packet.first, packet.second);
            });
            
            _decodedFrameCount++;
            _totalDecodeTimeMs += static_cast<int>(elapsed.to_milliseconds());
            
            // --- 리포트 전송 로직 (Strict Fix) ---
            {
                xstd::timestamp_t now = xstd::time::now();
                if (now - lastStatsReportTime >= REPORT_INTERVAL) {
                    lastStatsReportTime = now;
                    
                    PerformanceReport report;
                    // [필수 수정] 값을 읽고 0으로 초기화(Exchange)해야 구간 통계가 나옵니다.
                    report.receivedFrameCount = _receivedFrameCount.exchange(0);
                    report.decodedFrameCount = _decodedFrameCount.exchange(0);
                    report.droppedFrameCount = _droppedFrameCount.exchange(0);
                    
                    int decoded = report.decodedFrameCount;
                    int totalTime = _totalDecodeTimeMs.exchange(0); // 시간도 초기화
                    
                    if (decoded > 0) {
                        report.averageDecodeTimeMs = totalTime / decoded;
                    } else {
                        report.averageDecodeTimeMs = 0;
                    }
                    
                    channel->reportPerformanceReport(report);
                }
            }
        }
    }
    
    
    
private:
    // FIXME
    using VideoFramePacket = std::pair<FrameDataHeader, shared_data_ptr<uint8_t>>;
    
    inline size_t maxFrameQueueSize() {
        if (_preset == LOW_LATENCY) {
            return 2;
        } else {
            // FIXME ...
            return 5;
        }
    }
    
    std::shared_mutex _frameQueueMutex;
    xstd::condition_variable_t _frameQueueCondVar;
    std::queue<VideoFramePacket> _frameQueue;
    
    VideoClock _videoClock;
    
    xstd::atomic<int> _receivedFrameCount;
    xstd::atomic<int> _droppedFrameCount;
    xstd::atomic<int> _decodedFrameCount;
    xstd::atomic<int> _totalDecodeTimeMs;
    
    dispatch_queue_t _renderQueue;
}

```

</code>

```protobuf
// @opcode: 0x8001
message FrameDataHeader {
  fixed64 frameId = 1;
  // frameLength는 Protobuf 패킷 길이나 bytes 필드 길이로 대체되므로 제외 가능
  // 하지만 스트림 파싱 용도로 남겨둔다면 유지.
  fixed32 frameLength = 2;

  // PTS (Presentation Timestamp) - 마이크로초 단위 권장
  uint64 presentationTimestamp = 3;

  optional SRRect updatedRegion = 4;
  fixed32 flags = 15;
  // static const uint32_t FLAG_IS_KEYFRAME         = 0b00000001;
  // static const uint32_t FLAG_H264_HEVC_IS_ANNEXB = 0b;
}

message CodecParameterSet {
  // see CodecParameterSetType.hpp
  fixed64 type = 1;
  bytes data = 2;
  fixed32 flags = 3;
  // static const uint32_t FLAG_H264_HEVC_IS_ANNEXB = 0x00000001;
}
```

# CODEC PARAMETER SET
- 일부 코덱은 디코더를 셋업할 때 파라미터를 필요로 합니다.
  - H.264 (AVC) / H.265 (HEVC) 의 경우 SPS / PPS가 이에 해당합니다.
- 이 메시지는 해당 코덱 파라미터를 전달하는 용도로 사용됩니다.

## NOTE
- **FrameDataHeader** (0x8001)을 보내기 전에 이 메시지를 먼저 보내지 않으면,
  클라이언트 측에서 비디오 디코딩을 시도할 때 실패할 수 있습니다.

```protobuf
// @opcode: 0x8002
message CodecParameterSetMessage {
  repeated CodecParameterSet parameterSets = 1;
}
```

# PROJECTION CURSOR

# FLAGS
```optionset
optionset SubscribeCursorEventsFlags: uint32 {
    /// 커서 이미지를 캐싱하지 않을 것임을 서버에 알립니다.
    /// 서버 구현체는 이 플래그가 설정된 경우, 커서 이미지를 항상 전송해야 합니다.
    option disableImageCache = 0x1;
}
```

```protobuf
// @opcode: 0x80A1
message SubscribeCursorEventsRequest {
    uint64 requestId = 1;
    
    // @optionset: SubscribeCursorEventsFlags
    uint32 flags = 16;
}

// @opcode: 0x80A2
message SubscribeCursorEventsResponse {
    uint64 requestId = 1;
    /// 구독 식별자.
    SRUUID subscriptionId = 2;
}

// @opcode: 0x80A3
message UnsubscribeCursorEventsRequest {
    uint64 requestId = 1;
    /// 구독 식별자.
    SRUUID subscriptionId = 2;
}

// @opcode: 0x80A4
message UnsubscribeCursorEventsResponse {
    uint64 requestId = 1;
    /// 구독 식별자.
    SRUUID subscriptionId = 2;
    /// 구독 해제 성공 여부.
    bool isSuccess = 3;
}
```

# EVENT OBJECTS

## CursorMoveEvent

```protobuf
enum CursorMoveEvent {
    /// 커서가 현재 위치한 디스플레이 ID.
    /// 특수 값:
    ///   - `-1`은 다른 메시지에서 '기본 디스플레이'를 의미했지만, 여기서는 사용하지 않습니다 (assertion).
    ///   - `-2`는 전체 디스플레이 영역 (그래픽 세션의 전체 뷰포트)를 의미합니다.
    uint32 displayID = 1;
    
    /// 커서의 새로운 위치 (픽셀 단위).
    SRPoint position = 2;
}
```

### DESCRIPTION

마우스 포인터의 위치가 변경되었음을 나타내는 이벤트입니다. 서버는 클라이언트에게 이 이벤트를 전송하여 현재 커서 위치를 동기화할 수 있습니다.

### IMPLEMENTATION NOTES

- 서버 구현체는 이 이벤트를 적절히 스로틀링하거나 버퍼링하여 전송하는 기법을 고려하는 것이 좋습니다. 너무 빈번한 커서 이동 이벤트는 네트워크 대역폭을 낭비할 수 있습니다.

## CursorImageEvent

```protobuf
enum CursorImageEvent {
    /// 커서 유형 식별자.
    /// Note: 이 값은 서버 구현체 / OS마다 다를 수 있습니다. 커서 이미지 캐싱용으로만 사용하시기 바랍니다.
    uint64 cursorType = 1;
    
    /// 커서 이미지의 MIME 타입 (예: "image/png")
    string mimeType = 2;
    
    /// 커서 이미지의 크기
    SRSize size = 3;
    
    /// 커서 이미지 내에서 클릭 지점을 나타내는 좌표 (픽셀 단위, 이미지 좌상단 기준)
    SRPoint hotspot = 4;
    
    /// 커서 이미지 데이터 (바이너리)
    /// Note: 커서 이미지는 `disableImageCache` 플래그를 설정하지 않는 한, 처음 한 번만 전송됩니다.
    optional bytes imageData = 5;
}
```

### IMPLEMENTATION NOTES

- 커서 이미지 데이터의 크기는 되도록 16KB 이하로 유지하는 것이 좋습니다. 너무 큰 이미지는 전송 지연을 유발할 수 있습니다.

# EVENT MESSAGE (CONTAINER)

```protobuf
// @opcode: 0x80A5
message CursorEvent {
    oneof event {
        CursorMoveEvent moveEvent = 1;
        CursorImageEvent imageEvent = 2;
    }
}
```
